# ── Postgres ──
POSTGRES_USER=tgf
POSTGRES_PASSWORD=changeme
POSTGRES_DB=telegram_feed
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Redis ──
REDIS_HOST=redis
REDIS_PORT=6379

# ── MinIO ──
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme
MINIO_BUCKET=media
MINIO_SECURE=false

# ── Telegram userbot (ingester) ──
# Get api_id/api_hash at https://my.telegram.org/apps
TG_API_ID=
TG_API_HASH=
TG_PHONE=
TG_SESSION_NAME=userbot_main

# ── Telegram Bot (for TMA initData validation) ──
TG_BOT_TOKEN=

# ── API ──
API_JWT_SECRET=changeme-generate-with-openssl-rand-hex-32
API_JWT_ALGORITHM=HS256
API_JWT_ACCESS_TTL_SECONDS=3600
API_JWT_REFRESH_TTL_SECONDS=604800
API_CORS_ORIGINS=https://web.telegram.org

# ── Logging ──
LOG_LEVEL=INFO
LOG_FORMAT=json
ENV=local
