# ── Postgres ──
POSTGRES_USER=tgf
POSTGRES_PASSWORD=changeme
POSTGRES_DB=telegram_feed
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Redis ──
REDIS_HOST=redis
REDIS_PORT=6379

# ── MinIO ──
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme
MINIO_BUCKET=media
MINIO_SECURE=false

# ── Telegram userbot (ingester) ──
# Get api_id/api_hash at https://my.telegram.org/apps
TG_API_ID=
TG_API_HASH=
TG_PHONE=
TG_SESSION_NAME=userbot_main

# ── Telegram proxy (optional) ──
# TG_PROXY_TYPE: empty (direct), "mtproxy", or "socks5".
# For local dev: usually empty. Use "socks5" when the network blocks
# outbound to Telegram DCs and you want to tunnel via a sidecar.
#   socks5 via naive (default sidecar - terminates a NaiveProxy tunnel):
#     TG_PROXY_TYPE=socks5
#     TG_PROXY_HOST=naive
#     TG_PROXY_PORT=1080
#     TG_NAIVE_URL=naive+https://user:pass@host:port#name
#   socks5 via xray/VLESS (fallback - re-enable the xray sidecar per RUNBOOK):
#     TG_PROXY_HOST=xray   # and set TG_VLESS_URL below
#   mtproxy:
#     TG_PROXY_TYPE=mtproxy
#     TG_PROXY_HOST=mtp.example.com
#     TG_PROXY_PORT=443
#     TG_PROXY_SECRET=ee0000...   # 32-hex secret (with "ee" FakeTLS prefix if applicable)
TG_PROXY_TYPE=
TG_PROXY_HOST=
TG_PROXY_PORT=
TG_PROXY_SECRET=

# Used by naive-init when TG_PROXY_TYPE=socks5 (the default sidecar). Paste your
# naive+https:// share URI here - naive-init parses it into naive's config.json
# before the naive sidecar starts. Secret: keep .env out of git (it is) and chmod 600.
TG_NAIVE_URL=

# Fallback: VLESS via the xray sidecar. Paste a vless:// URL and re-enable the
# xray services per RUNBOOK to use VLESS instead of naive.
TG_VLESS_URL=

# ── Telegram Bot (for TMA initData validation) ──
TG_BOT_TOKEN=

# ── API ──
API_JWT_SECRET=changeme-generate-with-openssl-rand-hex-32
API_JWT_ALGORITHM=HS256
API_JWT_ACCESS_TTL_SECONDS=3600
API_JWT_REFRESH_TTL_SECONDS=604800
API_CORS_ORIGINS=https://web.telegram.org

# ── Logging ──
LOG_LEVEL=INFO
LOG_FORMAT=json
ENV=local
