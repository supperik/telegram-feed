# Production .env template for zupperik.dev deployment.
# On the VDS:
#   cp .env.prod.example .env
# then fill every <REPLACE_*> placeholder.
#
# Generate secrets with: openssl rand -hex 32

# ── Postgres ──────────────────────────────────────────────
POSTGRES_USER=tgf
POSTGRES_PASSWORD=<REPLACE_WITH_openssl_rand_hex_16>
POSTGRES_DB=telegram_feed
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Redis ────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── MinIO (S3-compatible photo storage) ───────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=<REPLACE_WITH_openssl_rand_hex_8>
MINIO_SECRET_KEY=<REPLACE_WITH_openssl_rand_hex_32>
MINIO_BUCKET=media
MINIO_SECURE=false

# ── Telegram userbot (ingester) ───────────────────────────
# Register an app at https://my.telegram.org/apps under your
# *userbot* Telegram account (separate from your main one!).
TG_API_ID=<from my.telegram.org/apps>
TG_API_HASH=<from my.telegram.org/apps>
TG_PHONE=<userbot phone with country code, e.g. +79991234567>
TG_SESSION_NAME=userbot_main

# ── Telegram proxy (optional) ─────────────────────────────
# TG_PROXY_TYPE: empty (direct), "mtproxy", or "socks5".
#
# socks5 (RECOMMENDED for prod if VDS blocks Telegram DC IPs):
#   docker-compose ships an xray sidecar that terminates a VLESS tunnel to
#   your own server. Paste the full vless:// URL into TG_VLESS_URL below
#   — the xray-init container parses it into the xray config.json before
#   the xray sidecar starts. Then point ingester at xray:1080:
#     TG_PROXY_TYPE=socks5
#     TG_PROXY_HOST=xray
#     TG_PROXY_PORT=1080
#     TG_VLESS_URL=vless://<uuid>@<host>:<port>?security=tls&sni=...&type=tcp#<name>
#
# mtproxy (legacy fallback):
#     TG_PROXY_TYPE=mtproxy
#     TG_PROXY_HOST=<host>
#     TG_PROXY_PORT=<port>
#     TG_PROXY_SECRET=<32-hex>
#
# Leave TG_PROXY_TYPE empty to connect directly.
TG_PROXY_TYPE=
TG_PROXY_HOST=
TG_PROXY_PORT=
TG_PROXY_SECRET=
TG_VLESS_URL=

# ── Telegram Bot (TMA initData validation) ────────────────
# Create via @BotFather → /newbot. Use the token printed by BotFather.
TG_BOT_TOKEN=<from @BotFather>

# ── API / JWT ─────────────────────────────────────────────
API_JWT_SECRET=<REPLACE_WITH_openssl_rand_hex_32>
API_JWT_ALGORITHM=HS256
API_JWT_ACCESS_TTL_SECONDS=3600
API_JWT_REFRESH_TTL_SECONDS=604800

# Allow Telegram WebApp, the TMA host, and the admin SPA host.
# If you skip admin.zupperik.dev for now, drop the third entry.
API_CORS_ORIGINS=https://web.telegram.org,https://zupperik.dev,https://admin.zupperik.dev

# ── Logging ──────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
ENV=prod
